<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/profile_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="@dimen/activity_horizontal_margin"
        android:paddingTop="@dimen/activity_vertical_margin"
        android:paddingRight="@dimen/activity_horizontal_margin"
        android:paddingBottom="@dimen/activity_vertical_margin"
        tools:context=".ProfileActivity">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/activity_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/teal_200"
            android:minHeight="?attr/actionBarSize"
            android:theme="?attr/actionBarTheme"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/home_option"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="@string/go_to_mainactivity"
            app:layout_constraintBottom_toBottomOf="@+id/activity_toolbar"
            app:layout_constraintEnd_toStartOf="@+id/profile_option"
            app:layout_constraintTop_toTopOf="@+id/activity_toolbar"
            app:srcCompat="@mipmap/ic_home" />

        <TextView
            android:id="@+id/profile_option"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="@string/profile"
            android:textColor="@color/black"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="@+id/activity_toolbar"
            app:layout_constraintEnd_toStartOf="@+id/account_option"
            app:layout_constraintTop_toTopOf="@+id/activity_toolbar" />

        <TextView
            android:id="@+id/account_option"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="@string/account"
            android:textColor="@color/black"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="@+id/activity_toolbar"
            app:layout_constraintEnd_toStartOf="@+id/action_signout"
            app:layout_constraintTop_toTopOf="@+id/activity_toolbar" />

        <ImageView
            android:id="@+id/action_signout"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginEnd="32dp"
            android:contentDescription="@string/logout"
            app:layout_constraintBottom_toBottomOf="@+id/activity_toolbar"
            app:layout_constraintEnd_toEndOf="@+id/activity_toolbar"
            app:layout_constraintTop_toTopOf="@+id/activity_toolbar"
            app:srcCompat="@mipmap/ic_logout" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvContacts"
            android:layout_width="350dp"
            android:layout_height="500dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/activity_toolbar"
            tools:listitem="@layout/item_post" />

        <TextView
            android:id="@+id/add"
            android:layout_width="150dp"
            android:layout_height="75dp"
            android:layout_marginTop="16dp"
            android:background="@color/teal_200"
            android:drawablePadding="4dp"
            android:gravity="center_vertical|center_horizontal"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:text="@string/add_photo"
            android:textColor="@color/black"
            android:textSize="20sp"
            app:drawableEndCompat="@mipmap/ic_add"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rvContacts" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>