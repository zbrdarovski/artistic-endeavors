            android:name="si.um.feri.artisticendeavors.ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="si.um.feri.artisticendeavors.ui.delete.DeleteActivity"
            android:exported="false" />
